<UserControl x:Class="APP_WPF.CTRL_VIEW"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:APP_WPF"
             mc:Ignorable="d" 
             Background="#0F0F1A">

    <UserControl.Resources>

        <!-- COULEURS -->
        <SolidColorBrush x:Key="BgCard"        Color="#1A1A2E"/>
        <SolidColorBrush x:Key="BgPanel"       Color="#16213E"/>
        <SolidColorBrush x:Key="AccentPurple"  Color="#7C3AED"/>
        <SolidColorBrush x:Key="AccentViolet"  Color="#A855F7"/>
        <SolidColorBrush x:Key="AccentCyan"    Color="#06B6D4"/>
        <SolidColorBrush x:Key="AccentGreen"   Color="#10B981"/>
        <SolidColorBrush x:Key="AccentRed"     Color="#EF4444"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextDim"       Color="#475569"/>

        <LinearGradientBrush x:Key="GradPurple" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#7C3AED" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradCyan" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0891B2" Offset="0"/>
            <GradientStop Color="#06B6D4" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradGreen" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#059669" Offset="0"/>
            <GradientStop Color="#10B981" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GradRed" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#DC2626" Offset="0"/>
            <GradientStop Color="#EF4444" Offset="1"/>
        </LinearGradientBrush>

        <!-- BOUTON RÉPONSE -->
        <Style x:Key="BtnReponse" TargetType="Button">
            <Setter Property="Background"      Value="#1A1A2E"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Padding"         Value="16,14"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush"     Value="#2D2D4E"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="#16213E"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentPurple}"/>
                            </Trigger>
                            
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BOUTON SUIVANT -->
        <Style x:Key="BtnSuivant" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource GradPurple}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"      Value="Segoe UI Semibold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Padding"         Value="28,11"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── BARRE PROGRESSION ── -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPanel}"
                Padding="32,14,32,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- N° question -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="QUESTION"
                               FontFamily="Segoe UI Semibold" FontSize="10"
                               Foreground="{StaticResource TextDim}"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Tag="LBL_Q_ACTUELLE"
                                   x:Name="tbx_Q_acutellle"
                                   Text="1"
                                   FontFamily="Segoe UI Black" FontSize="28"
                                   Foreground="{StaticResource AccentViolet}"/>
                        <TextBlock Tag="LBL_Q_TOTAL"
                                   x:Name="tbx_q_total"
                                   Text=" / 10"
                                   FontFamily="Segoe UI" FontSize="18"
                                   Foreground="{StaticResource TextMuted}"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,0,4"/>
                    </StackPanel>
                </StackPanel>

                <!-- Barre de progression -->
                <Border Grid.Column="1"
                        Background="#16213E"
                        CornerRadius="4" Height="8"
                        Margin="24,0,24,0"
                        VerticalAlignment="Center">
                    <Border Tag="PROGRESS_BAR"
                            x:Name="brd_progress_bar"
                            CornerRadius="4"
                            
                            HorizontalAlignment="Left">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Green" Offset="0"/>
                                <GradientStop Color="Green" Offset="1"/>
                                
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Border>

                <!-- Score -->
                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── BADGES CATÉGORIE / DIFFICULTÉ ── -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="32,14,32,0">
            <Border Background="#1E1B4B"
                    CornerRadius="20"
                    Padding="12,5">
                <TextBlock Tag="LBL_CATEGORIE_QUIZ"
                           Text="🎮 Jeux vidéos"
                           x:Name="tbx_categorie"
                           FontFamily="Segoe UI Semibold" FontSize="12"
                           Foreground="{StaticResource AccentViolet}"/>
            </Border>
            <Border Background="#0C4A6E"
                    CornerRadius="20"
                    Padding="12,5"
                    Margin="8,0,0,0">
                <TextBlock Tag="LBL_DIFFICULTE_QUIZ"
                           x:Name="tbx_difficulte"
                           Text="⚡ Facile"
                           FontFamily="Segoe UI Semibold" FontSize="12"
                           Foreground="{StaticResource AccentCyan}"/>
            </Border>
        </StackPanel>

        <!-- ── QUESTION + RÉPONSES ── -->
        <Grid Grid.Row="2" Margin="32,16,32,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Texte question -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgCard}"
                    CornerRadius="14"
                    Padding="28,20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.3"
                                      BlurRadius="20" ShadowDepth="2"/>
                </Border.Effect>
                <TextBlock Tag="LBL_QUESTION"
                           Text="La question s'affichera ici..."
                           x:Name="TB_question"
                           FontFamily="Segoe UI" FontSize="16"
                           Foreground="{StaticResource TextPrimary}"
                           TextWrapping="Wrap"
                           LineHeight="25"/>
            </Border>

            <!-- Grille 2x2 des réponses -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Réponse A -->
                <Button Tag="BTN_REP_A"
                        x:Name="Btn_A"
                        Click="Btn_A_Click"
                        Grid.Row="0" Grid.Column="0"
                        Style="{StaticResource BtnReponse}">
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="5" Width="26" Height="26"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                    <GradientStop Color="#A855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="A" FontFamily="Segoe UI Black"
                                       FontSize="12" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Tag="TXT_REP_A" Text="Réponse A"
                                   x:Name="Tb_Rep_A"
                                   TextWrapping="Wrap" MaxWidth="260"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Réponse B -->
                <Button Tag="BTN_REP_B"
                        x:Name="Btn_B"
                        Click="Btn_B_Click"
                        Grid.Row="0" Grid.Column="2"
                        Style="{StaticResource BtnReponse}">
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="5" Width="26" Height="26"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0891B2" Offset="0"/>
                                    <GradientStop Color="#06B6D4" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="B" FontFamily="Segoe UI Black"
                                       FontSize="12" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Tag="TXT_REP_B" Text="Réponse B"
                                   TextWrapping="Wrap" MaxWidth="260"
                                   x:Name="TB_Rep_B"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Réponse C -->
                <Button Tag="BTN_REP_C"
                        x:Name="Btn_C"
                        Click="Btn_C_Click"
                        Grid.Row="2" Grid.Column="0"
                        Style="{StaticResource BtnReponse}">
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="5" Width="26" Height="26"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#059669" Offset="0"/>
                                    <GradientStop Color="#10B981" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="C" FontFamily="Segoe UI Black"
                                       FontSize="12" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Tag="TXT_REP_C" Text="Réponse C"
                                   TextWrapping="Wrap" MaxWidth="260"
                                   x:Name="TB_Rep_C"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Réponse D -->
                <Button Tag="BTN_REP_D"
                        x:Name="Btn_D"
                        Click="Btn_D_Click"
                        Grid.Row="2" Grid.Column="2"
                        Style="{StaticResource BtnReponse}">
                    <StackPanel Orientation="Horizontal">
                        <Border CornerRadius="5" Width="26" Height="26"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#DC2626" Offset="0"/>
                                    <GradientStop Color="#EF4444" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="D" FontFamily="Segoe UI Black"
                                       FontSize="12" Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Tag="TXT_REP_D" Text="Réponse D"
                                   TextWrapping="Wrap" MaxWidth="260"
                                   x:Name="TB_Rep_D"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Grid>

        <!-- ── BAS : FEEDBACK + SUIVANT ── -->
        <Grid Grid.Row="3" Margin="32,10,32,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Feedback bonne/mauvaise réponse -->
            <Border Tag="FEEDBACK_PANEL"
                    Grid.Column="0"
                    CornerRadius="10" Padding="16,10"
                    Visibility="Collapsed"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"
                    Background="#0D1F12">
                <TextBlock Tag="LBL_FEEDBACK"
                           Text="✅  Bonne réponse !"
                           FontFamily="Segoe UI Semibold" FontSize="14"
                           Foreground="{StaticResource AccentGreen}"/>
            </Border>

            <!-- Bouton Suivant -->
            <Button Tag="BTN_SUIVANT"
                    Grid.Column="1"
                    Content="Suivant  →"
                    Style="{StaticResource BtnSuivant}"
                    IsEnabled="False"
                    x:Name="Btn_Suivant"
                    Click="Btn_Suivant_Click"/>
        </Grid>

    </Grid>
</UserControl>

